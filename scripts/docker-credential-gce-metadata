#!/bin/bash
# Docker credential helper for GCE: fetches Artifact Registry tokens from the
# instance metadata server. No credentials are stored on disk.
# Install: copy to VM, chmod +x, add to PATH; set credHelpers in ~/.docker/config.json.
# See docs/GH-ACTIONS-DEPLOY.md and docs/DEPLOYMENT-CHECKLIST.md.

set -e
cmd="${1:-}"
server_url=""
if [[ -n "$cmd" ]]; then
  if [[ "$cmd" == "get" ]]; then
    read -r server_url
  fi
else
  read -r line1
  if [[ "$line1" == "get" ]]; then
    read -r server_url
  elif [[ "$line1" == *"docker.pkg.dev"* ]]; then
    server_url="$line1"
  fi
fi
if [[ -n "$server_url" && "$server_url" == *"docker.pkg.dev"* ]]; then
  token=$(curl -sS -f -H "Metadata-Flavor: Google" \
    "http://metadata.google.internal/computeMetadata/v1/instance/service-accounts/default/token") || { echo "curl failed" >&2; exit 1; }
  echo "$token" | python3 -c "
import sys, json
t = json.load(sys.stdin)
print(json.dumps({'Username': 'oauth2accesstoken', 'Secret': t['access_token']}))
" || { echo "python failed" >&2; exit 1; }
elif [[ "$cmd" == "store" || "$cmd" == "erase" || "$line1" == "store" || "$line1" == "erase" ]]; then
  exit 0
else
  exit 1
fi
