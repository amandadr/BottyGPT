# Multi-stage build: Node for Vite build, Nginx for production static serving.
# Build with: docker build -f Dockerfile.production --build-arg VITE_API_HOST=https://assistant-api.mannyroy.com -t docsgpt-fe .

# Stage 1: Build
FROM node:22-alpine AS build-stage
WORKDIR /app
COPY package*.json ./
RUN npm ci --ignore-scripts
COPY . .
ARG VITE_API_HOST=https://assistant-api.mannyroy.com
ARG VITE_API_STREAMING=true
ARG VITE_BASE_URL=https://assistant.mannyroy.com
ARG VITE_GOOGLE_CLIENT_ID
ENV VITE_API_HOST=$VITE_API_HOST
ENV VITE_API_STREAMING=$VITE_API_STREAMING
ENV VITE_BASE_URL=$VITE_BASE_URL
ENV VITE_GOOGLE_CLIENT_ID=$VITE_GOOGLE_CLIENT_ID
RUN npx vite build
# Remove source maps to reduce layer size and avoid overlayfs extraction errors on some runtimes
RUN find /app/dist -name '*.map' -delete

# Stage 2: Production
FROM nginx:stable-alpine AS production-stage
COPY --from=build-stage /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
